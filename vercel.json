{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/gerar-carrossel", "dest": "/api/gerar-carrossel.js" },
    { "src": "/api/montar-canva", "dest": "/api/montar-canva.js" },
    { "src": "/api/get-pending", "dest": "/api/get-pending.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
